<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DewEncryption.Gui.MainWindow"
        Title="Dew Encryption"
        Width="1180"
        Height="780"
        MinWidth="980"
        MinHeight="640">
  <Grid RowDefinitions="Auto,*,Auto" Margin="18">
    <Border Grid.Row="0" Classes="topbar">
      <DockPanel>
        <StackPanel DockPanel.Dock="Left">
          <TextBlock Text="Dew Encryption" Classes="title" />
          <TextBlock Text="Files, history, containers, and Dew Drive" Classes="subtitle" />
        </StackPanel>
        <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
          <Button Content="CLI Help" Classes="secondary" Click="OpenHelp_Click" />
          <TextBlock x:Name="StatusText" Text="Ready" Classes="subtitle" HorizontalAlignment="Right" Margin="0,8,8,0" />
        </StackPanel>
      </DockPanel>
    </Border>

    <TabControl Grid.Row="1" Margin="0,14,0,14">
      <TabItem Header="Files">
        <Grid ColumnDefinitions="2*,360" Margin="0,12,0,0">
          <Border Classes="panel" Margin="0,0,14,0">
            <Grid RowDefinitions="Auto,*">
              <StackPanel Orientation="Horizontal">
                <Button Content="Add Files" Classes="secondary" Click="AddFiles_Click" />
                <Button Content="Add Folder" Classes="secondary" Click="AddFolder_Click" />
                <Button Content="Remove" Click="RemoveSelected_Click" />
                <Button Content="Run" Classes="primary" Click="RunSelected_Click" />
              </StackPanel>
              <DataGrid x:Name="FilesGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Extended" Margin="0,12,0,0">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*" />
                  <DataGridTextColumn Header="Type" Binding="{Binding Kind}" Width="120" />
                </DataGrid.Columns>
              </DataGrid>
            </Grid>
          </Border>

          <Border Classes="panel" Grid.Column="1">
            <StackPanel>
              <TextBlock Text="Selection" Classes="sectionTitle" />
              <TextBlock x:Name="SelectionSummaryText" Classes="muted" Margin="0,8,0,16" TextWrapping="Wrap" />
              <TextBlock Text="History Repo" Classes="label" />
              <TextBox x:Name="HistoryTargetBox" IsReadOnly="True" Margin="0,6,0,16" />
              <StackPanel Orientation="Horizontal">
                <Button Content="Refresh History" Classes="secondary" Click="RefreshHistory_Click" />
                <Button Content="Snapshot" Classes="primary" Click="SnapshotHistory_Click" />
              </StackPanel>
              <Button Content="Open History Manager" Margin="0,10,8,0" Click="OpenPythonHistoryGui_Click" />
            </StackPanel>
          </Border>
        </Grid>
      </TabItem>

      <TabItem Header="Containers">
        <Grid ColumnDefinitions="340,*" Margin="0,12,0,0">
          <Border Classes="panel" Margin="0,0,14,0">
            <Grid RowDefinitions="Auto,*">
              <TextBlock Text="Saved Containers" Classes="sectionTitle" />
              <ListBox x:Name="ContainersList" Grid.Row="1" Margin="0,10,0,0" SelectionChanged="ContainersList_SelectionChanged" />
            </Grid>
          </Border>

          <Border Classes="panel" Grid.Column="1">
            <Grid RowDefinitions="Auto,Auto,Auto,*">
              <UniformGrid Columns="2" Rows="4">
                <TextBox Watermark="Name" x:Name="ContainerNameBox" Margin="0,0,8,8" />
                <TextBox Watermark="Container path" x:Name="ContainerPathBox" Margin="0,0,0,8" />
                <TextBox Watermark="Mount path" x:Name="MountPathBox" Margin="0,0,8,8" />
                <TextBox Watermark="Font family" x:Name="FontFamilyBox" Text="Segoe UI" Margin="0,0,0,8" />
                <TextBox Watermark="Background color" x:Name="BackgroundBox" Text="#172033" Margin="0,0,8,8" />
                <TextBox Watermark="Foreground color" x:Name="ForegroundBox" Text="#F8FAFC" Margin="0,0,0,8" />
                <TextBox Watermark="Accent color" x:Name="AccentBox" Text="#0F766E" Margin="0,0,8,8" />
                <TextBox Watermark="Font size" x:Name="FontSizeBox" Text="10" Margin="0,0,0,8" />
              </UniformGrid>
              <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,12">
                <Button Content="Save Container" Classes="primary" Click="RegisterContainer_Click" />
                <Button Content="Snapshot" Classes="secondary" Click="SnapshotContainer_Click" />
                <Button Content="History" Classes="secondary" Click="ViewContainerHistory_Click" />
                <Button Content="Test Open" Click="TestOpenHooks_Click" />
                <Button Content="Test Close" Click="TestCloseHooks_Click" />
              </StackPanel>
              <TextBox Grid.Row="2" x:Name="HookBox" Height="86" AcceptsReturn="True" Watermark="Hook notes" TextWrapping="Wrap" />
              <TextBlock Grid.Row="3" x:Name="ContainerStatusText" Classes="muted" Margin="0,12,0,0" TextWrapping="Wrap" />
            </Grid>
          </Border>
        </Grid>
      </TabItem>

      <TabItem Header="Dew Drive">
        <Grid ColumnDefinitions="340,*" Margin="0,12,0,0">
          <Border Classes="panel" Margin="0,0,14,0">
            <Grid RowDefinitions="Auto,*">
              <TextBlock Text="Stream Folders" Classes="sectionTitle" />
              <ListBox x:Name="DriveProfilesList" Grid.Row="1" Margin="0,10,0,0" SelectionChanged="DriveProfilesList_SelectionChanged" />
            </Grid>
          </Border>

          <Border Classes="panel" Grid.Column="1">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
              <TextBlock Text="Stream Folder" Classes="sectionTitle" />
              <UniformGrid Grid.Row="1" Columns="2" Rows="2">
                <TextBox Watermark="Drive name" x:Name="DriveNameBox" Margin="0,8,8,8" />
                <TextBox Watermark="Upload image tag" x:Name="DriveRegistryImageBox" ToolTip.Tip="Docker/OCI image tag, for example docker.io/your-name/dew-drive:latest. This is the upload target, not a Dockerfile." Margin="0,8,0,8" />
                <TextBox Watermark="Local stream folder" x:Name="DriveFolderBox" Margin="0,0,8,8" />
                <TextBox Watermark="Restore commit" x:Name="DriveCommitBox" Text="HEAD" Margin="0,0,0,8" />
              </UniformGrid>
              <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,12">
                <Button Content="Save Profile" Classes="primary" Click="NewDrive_Click" />
                <Button Content="Delete" Classes="outline" Click="DeleteDrive_Click" />
                <Button Content="Pick Folder" Classes="secondary" Click="PickDriveFolder_Click" />
                <Button Content="Add Files" Classes="outline" Click="AddDriveFiles_Click" />
                <Button Content="Add Folder" Classes="outline" Click="AddDriveFolder_Click" />
              </StackPanel>

              <TextBlock Grid.Row="3" Text="Encryption" Classes="sectionTitle" Margin="0,2,0,8" />
              <UniformGrid Grid.Row="4" Columns="4" Rows="2">
                <ComboBox x:Name="DriveEncryptionModeBox" SelectedIndex="1" Margin="0,0,8,8">
                  <ComboBoxItem Content="7zip" />
                  <ComboBoxItem Content="veracrypt" />
                </ComboBox>
                <TextBox x:Name="DrivePasswordBox" Watermark="Password" PasswordChar="*" Margin="0,0,8,8" />
                <TextBox x:Name="DriveVeraCryptPathBox" Watermark="VeraCrypt path" Margin="0,0,8,8" />
                <TextBox x:Name="DriveVcPimBox" Watermark="PIM" Text="0" Margin="0,0,0,8" />
                <TextBox x:Name="DriveVcEncryptionBox" Watermark="Algorithm" Text="AES" Margin="0,0,8,8" />
                <TextBox x:Name="DriveVcHashBox" Watermark="Hash" Text="SHA-512" Margin="0,0,8,8" />
                <TextBox x:Name="DriveVcFilesystemBox" Watermark="Filesystem" Text="exFAT" Margin="0,0,8,8" />
                <StackPanel Orientation="Horizontal" Margin="0,8,0,8">
                  <CheckBox x:Name="DriveAutoPushBox" Content="Auto push" ToolTip.Tip="Watch this profile when startup auto-sync launches." Margin="0,0,10,0" />
                  <CheckBox x:Name="DriveStartAtLoginBox" Content="Startup" ToolTip.Tip="Start Dew Drive auto-sync when this Windows user signs in." Click="DriveStartAtLogin_Click" />
                </StackPanel>
              </UniformGrid>
              <WrapPanel Grid.Row="5" Margin="0,0,0,12">
                <Button Content="Install VC" Classes="tonal" Click="InstallVeraCrypt_Click" />
                <Button Content="Save VC Settings" Classes="outline" Click="SaveVeraCryptSettings_Click" />
                <Button Content="Auto Sync" Classes="primary" Click="StartDriveAutoSync_Click" />
                <Button Content="Stop" Classes="outline" Click="StopDriveAutoSync_Click" />
                <Button Content="Sync" Classes="secondary" Click="SyncDrive_Click" />
                <Button Content="Push" Classes="primary" Click="SyncPushDrive_Click" />
                <Button Content="Pull" Classes="secondary" Click="PullDrive_Click" />
                <Button Content="Restore" Classes="outline" Click="RestoreDrive_Click" />
              </WrapPanel>
              <TextBlock Grid.Row="6" x:Name="DriveStatusText" Classes="muted" TextWrapping="Wrap" />
              <TextBox x:Name="DriveItemsBox" IsVisible="False" />
            </Grid>
          </Border>
        </Grid>
      </TabItem>
    </TabControl>

    <Border Grid.Row="2" Classes="panel">
      <Grid RowDefinitions="Auto,*">
        <TextBlock Text="Activity" Classes="sectionTitle" />
        <TextBox x:Name="LogBox" Grid.Row="1" Height="64" AcceptsReturn="True" IsReadOnly="True" TextWrapping="Wrap" Margin="0,8,0,0" />
      </Grid>
    </Border>
  </Grid>
</Window>
