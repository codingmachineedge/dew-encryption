<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DewEncryption.Gui.App">
  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />
    <Style Selector="Window">
      <Setter Property="FontFamily" Value="Inter, Segoe UI, Arial" />
      <Setter Property="Background" Value="#F5F7FA" />
    </Style>
    <Style Selector="Border.panel">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#D8E0EA" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="14" />
    </Style>
    <Style Selector="Border.topbar">
      <Setter Property="Background" Value="#172033" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="18" />
    </Style>
    <Style Selector="TextBlock.title">
      <Setter Property="FontSize" Value="24" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>
    <Style Selector="TextBlock.subtitle">
      <Setter Property="Foreground" Value="#C9D7E8" />
    </Style>
    <Style Selector="TextBlock.sectionTitle">
      <Setter Property="FontSize" Value="15" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#202938" />
    </Style>
    <Style Selector="TextBlock.label">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#48566A" />
    </Style>
    <Style Selector="TextBlock.muted">
      <Setter Property="Foreground" Value="#64748B" />
    </Style>
    <Style Selector="Button">
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="Margin" Value="0,0,8,0" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="#0F766E" />
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>
    <Style Selector="Button.secondary">
      <Setter Property="Background" Value="#EAF1F8" />
      <Setter Property="Foreground" Value="#1E293B" />
    </Style>
    <Style Selector="TextBox">
      <Setter Property="MinHeight" Value="34" />
    </Style>
  </Application.Styles>
</Application>
